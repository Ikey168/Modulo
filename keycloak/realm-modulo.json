{
  "realm": "modulo",
  "enabled": true,
  "loginTheme": "modulo",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 900,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Full administrative access" },
      { "name": "editor", "description": "Can create and edit notes" },
      { "name": "viewer", "description": "Read-only access" },
      { "name": "plugin-developer", "description": "Can develop and submit plugins" },
      { "name": "plugin-reviewer", "description": "Can review plugin submissions" }
    ]
  },
  "clients": [
    {
      "clientId": "modulo-frontend",
      "name": "Modulo Frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost/*",
        "http://localhost:80/*",
        "http://localhost:3001/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      }
    }
  ],
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "emailVerified": true,
      "email": "demo@modulo.local",
      "firstName": "Demo",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "demo", "temporary": false }
      ],
      "realmRoles": ["admin"]
    }
  ]
}
