# Modulo on a Raspberry Pi 5 — copy to .env and fill in EVERY value (#386).
# The compose file refuses to start with missing secrets (no insecure defaults).

# ── Public URL ───────────────────────────────────────────────────────────────
# How browsers reach the Pi. Examples:
#   LAN by IP:        MODULO_URL=http://192.168.1.50    MODULO_DOMAIN=:80
#   LAN by mDNS:      MODULO_URL=http://modulo.local    MODULO_DOMAIN=modulo.local:80
#   Tailscale:        MODULO_URL=http://pi.tailnet-name.ts.net   MODULO_DOMAIN=pi.tailnet-name.ts.net:80
#   Public + HTTPS:   MODULO_URL=https://modulo.example.com      MODULO_DOMAIN=modulo.example.com
# MODULO_URL is baked into the frontend at build time — rebuild after changing it.
MODULO_URL=http://modulo.local
MODULO_DOMAIN=modulo.local:80

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DB=modulodb
POSTGRES_USER=modulo
# openssl rand -base64 24
POSTGRES_PASSWORD=

# ── Neo4j ────────────────────────────────────────────────────────────────────
# openssl rand -base64 24  (no '/' characters — used in NEO4J_AUTH)
NEO4J_PASSWORD=

# ── Keycloak admin ───────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
# openssl rand -base64 24
KEYCLOAK_ADMIN_PASSWORD=

# ── Application secrets ──────────────────────────────────────────────────────
# JWT secret, base64: openssl rand -base64 48
MODULO_SECURITY_JWT_SECRET=
# API key, must start with "mod_": echo "mod_$(openssl rand -hex 16)"
MODULO_SECURITY_API_KEY=
# Encryption key, exactly 32 characters: openssl rand -hex 16
MODULO_SECURITY_ENCRYPTION_KEY=

# ── Optional: on-chain anchoring ─────────────────────────────────────────────
# An L2 RPC endpoint (e.g. Base/Arbitrum via your provider) and network name.
# Leave commented out to run without anchoring — the feature degrades
# gracefully (anchor attempts log a warning; everything else works).
#BLOCKCHAIN_RPC_URL=https://mainnet.base.org
#BLOCKCHAIN_NETWORK=base
