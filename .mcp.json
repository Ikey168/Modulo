{
  "mcpServers": {
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres_dev:postgres_dev@localhost:5432/modulodb_dev"
      ],
      "env": {}
    },
    "docker": {
      "type": "stdio",
      "command": "python3",
      "args": ["tools/docker_mcp/server.py"],
      "env": {}
    },
    "neo4j": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-neo4j-cypher@latest", "--transport", "stdio"],
      "env": {
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_PASSWORD": "stagingpassword123",
        "NEO4J_DATABASE": "neo4j"
      }
    }
  }
}
