# Keycloak OIDC Configuration
VITE_KEYCLOAK_URL=http://localhost:8080/realms/modulo
VITE_KEYCLOAK_CLIENT_ID=modulo-frontend

# API Configuration  
VITE_API_BASE_URL=http://localhost:8090

# Optional: Development settings
VITE_ENABLE_DEBUG_LOGS=true

# Dev-only: bypass the OIDC login and enter the app as a mock user.
# Set to "true" to preview the workspace without running Keycloak.
# Never enable this in a production build.
VITE_DEV_BYPASS_AUTH=false
